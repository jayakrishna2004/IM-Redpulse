# =============================================
# RedPulse Local Environment Configuration
# =============================================

# Database
DATABASE_URL=postgresql://redpulse_user:redpulse_pass@localhost:5432/redpulse

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=redpulse-super-secret-jwt-key-local-dev-2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Backend ports
CORE_API_PORT=3001
AI_ENGINE_PORT=8000

# Frontend URLs (for CORS)
DASHBOARD_URL=http://localhost:5173
MOBILE_URL=http://localhost:8081

# AI Engine
AI_ENGINE_URL=http://localhost:8000

# Map (using OpenStreetMap - no key needed)
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Matching Engine Config
INITIAL_RADIUS_KM=3
RADIUS_EXPANSION_KM=2
EXPANSION_INTERVAL_MS=120000
MAX_RADIUS_KM=20
TOP_DONORS_PER_BATCH=5

# Notification timeout (ms)
NOTIFICATION_TIMEOUT_MS=30000

# Demo mode (uses seeded data + simulated locations)
DEMO_MODE=true

# Mail / SES Config (AWS SES Native SDK)
EXTERNAL_HUB_URL=https://odrcd3vaee.execute-api.us-east-1.amazonaws.com/stage1/send
SES_REGION=us-east-1
SES_SANDBOX_OVERRIDE_EMAIL=dundigalmahith@gmail.com
SES_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
SES_SECRET_KEY=YOUR_AWS_SECRET_KEY
MAIL_FROM=notifications@your-verified-domain.com

# SMS Whitelisting & Sandbox (E.164 Format: +91...)
# Set this to YOUR phone number to receive ALL outgoing SMS for testing
SES_SANDBOX_OVERRIDE_PHONE=+919347653931
# Comma-separated list for broader testing (or '*' to allow all)
SMS_WHITELIST=+919347653931

# Standard SMTP Fallback (Ethereal)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587

# Local Network IP
LOCAL_IP=172.29.135.15
TUNNEL_URL=https://potatoes-champagne-cancelled-accordingly.trycloudflare.com